local function doLockOn()
    lockedTarget = getClosestTargetToMouse()
    if not lockedTarget then
        warn("No target found near mouse")
        return
    end
    lockOnActive = true
    TweenService:Create(lockOnBtn, TweenInfo.new(0.15), {
        ImageColor3 = Color3.fromRGB(255, 60, 60)
    }):Play()
    RunService:BindToRenderStep("LockOnCam", Enum.RenderPriority.Camera.Value + 1, function()
        if not lockOnActive then return end
        -- Update target each frame to follow mouse
        local newTarget = getClosestTargetToMouse()
        if newTarget then lockedTarget = newTarget end

        if not lockedTarget or not lockedTarget.Parent or
           not lockedTarget:FindFirstChild("HumanoidRootPart") or
           lockedTarget:GetAttribute("Dead") then
            doUnlockOn()
            return
        end
        local myChar = LocalPlayer.Character
        if not myChar then return end
        if table.find(lockMethod, "Camera") then
            workspace.CurrentCamera.CameraType = Enum.CameraType.Track
            local camPos = workspace.CurrentCamera.CFrame.Position
            local tHRP = lockedTarget:FindFirstChild("HumanoidRootPart")
            if tHRP then
                workspace.CurrentCamera.CFrame = workspace.CurrentCamera.CFrame:Lerp(
                    CFrame.new(camPos, tHRP.Position + workspace.CurrentCamera.CFrame.RightVector * 1.75), 0.9
                ) - workspace.CurrentCamera.CFrame.Position + camPos
            end
        end
        if table.find(lockMethod, "Character") then
            myChar.Humanoid.AutoRotate = false
            local hrp = myChar:FindFirstChild("HumanoidRootPart")
            local tHRP = lockedTarget:FindFirstChild("HumanoidRootPart")
            if hrp and tHRP then
                hrp.CFrame = CFrame.new(hrp.Position, Vector3.new(tHRP.Position.X, hrp.Position.Y, tHRP.Position.Z))
            end
        end
    end)
end

