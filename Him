    for i = 1, 3 do
        hrp.CFrame = dest * CFrame.new(
            math.random(-1, 1) * 0.05,
            math.random(-1, 1) * 0.05,
            math.random(-1, 1) * 0.05
        )
        hrp.AssemblyLinearVelocity = Vector3.zero
    end
    hrp.CFrame = dest

    -- Optional velocity spoof (no wait)
    -- local disp = dest.Position - oldPos
    -- if disp.Magnitude > 0.5 then hrp.AssemblyLinearVelocity = disp * 80 end

    if tpBypassOn then antistuff() end  -- instantly re-enable
    workspace.FallenPartsDestroyHeight = -150
end

