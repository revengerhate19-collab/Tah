-- ==========================================
local function getNearestTarget()
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end
    local nearest, minDist = nil, math.huge

    -- 1) Players
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local tChar = p.Character
            if tChar then
                local tHRP = tChar:FindFirstChild("HumanoidRootPart")
                local tHum = tChar:FindFirstChildOfClass("Humanoid")
                if tHRP and tHum and tHum.Health > 0 then
                    local dist = (myHRP.Position - tHRP.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        nearest = {character = tChar, root = tHRP, humanoid = tHum}
                    end
                end
            end
        end
    end

    -- 2) NPCs (any Model in workspace with Humanoid + HumanoidRootPart)
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= myChar then
            local isPlayer = false
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Character == obj then isPlayer = true; break end
            end
            if not isPlayer then
                local tHRP = obj:FindFirstChild("HumanoidRootPart")
                local tHum = obj:FindFirstChildOfClass("Humanoid")
                if tHRP and tHum and tHum.Health > 0 then
                    local dist = (myHRP.Position - tHRP.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        nearest = {character = obj, root = tHRP, humanoid = tHum}
                    end
                end
            end
        end
    end

    return nearest
end

