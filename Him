-- Get closest target (player or NPC) to the mouse cursor
local function getClosestTargetToMouse()
    local mousePos = UserInputService:GetMouseLocation()
    local camera = workspace.CurrentCamera
    local viewportSize = camera.ViewportSize
    local bestDist = math.huge
    local bestTarget = nil

    -- Search players
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local char = p.Character
            if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChildOfClass("Humanoid") and char:GetAttribute("Dead") ~= true then
                local hrp = char.HumanoidRootPart
                local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestTarget = char
                    end
                end
            end
        end
    end

    -- Search NPCs (workspace.Characters)
    local npcFolder = workspace:FindFirstChild("Characters")
    if npcFolder then
        for _, npc in ipairs(npcFolder:GetChildren()) do
            if npc:FindFirstChild("HumanoidRootPart") and npc:FindFirstChildOfClass("Humanoid") and npc:GetAttribute("Dead") ~= true then
                local hrp = npc.HumanoidRootPart
                local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestTarget = npc
                    end
                end
            end
        end
    end

    return bestTarget
end

